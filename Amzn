#include <iostream>
#include <string>
#include <cstdio>
#include <memory>
#include <thread>
#include <chrono>
#include <array>
#include <vector>
#include <algorithm>

using namespace std;

//==================== UTIL ====================//

string exec(const string& cmd) {
    array<char, 256> buffer;
    string result;

    unique_ptr<FILE, decltype(&pclose)> pipe(popen(cmd.c_str(), "r"), pclose);
    if (!pipe) return "";

    while (fgets(buffer.data(), buffer.size(), pipe.get()) != nullptr) {
        result += buffer.data();
    }

    return result;
}

double extractPrice(const string& response) {
    const string key = "\"regularMarketPrice\":";
    size_t pos = response.find(key);

    if (pos == string::npos) return -1;

    pos += key.length();

    char* endPtr;
    double price = strtod(response.c_str() + pos, &endPtr);

    return (endPtr == response.c_str() + pos) ? -1 : price;
}

double getPrice(const string& symbol) {
    static const string base =
        "curl -s --connect-timeout 2 \"https://query1.finance.yahoo.com/v7/finance/quote?symbols=";

    string response = exec(base + symbol + "\"");
    if (response.empty()) return -1;

    return extractPrice(response);
}

//==================== VOLATILITY ====================//

double calculateVolatility(const vector<double>& prices) {
    if (prices.size() < 2) return 0.0;

    double maxP = *max_element(prices.begin(), prices.end());
    double minP = *min_element(prices.begin(), prices.end());

    return (maxP - minP) / minP; // simple range-based volatility
}

//==================== MAIN ====================//

int main() {
    const string symbol = "AMZN";

    double cash = 10000.0;
    double shares = 0.0;
    double entry = 0.0;

    double maxEquity = cash;

    const double riskPerTrade = 0.01;   // 1%
    const double maxDrawdown = 0.10;    // 10%
    const int cooldownSec = 10;

    vector<double> priceHistory;
    const size_t maxHistory = 20;

    auto lastTradeTime = chrono::steady_clock::now();

    cout << "=== LIVE TRADING SIM (ADVANCED RM) ===\n";

    while (true) {
        double price = getPrice(symbol);

        if (price <= 0) {
            cout << "DATA ERROR\n";
            this_thread::sleep_for(chrono::seconds(2));
            continue;
        }

        // store price history
        priceHistory.push_back(price);
        if (priceHistory.size() > maxHistory)
            priceHistory.erase(priceHistory.begin());

        double volatility = calculateVolatility(priceHistory);

        double equity = cash + shares * price;
        maxEquity = max(maxEquity, equity);

        // 🔴 Max drawdown protection
        if ((maxEquity - equity) / maxEquity > maxDrawdown) {
            cout << "MAX DRAWDOWN HIT. STOPPING.\n";
            break;
        }

        cout << "Price: " << price 
             << " | Volatility: " << volatility << "\n";

        auto now = chrono::steady_clock::now();
        bool cooldownPassed =
            chrono::duration_cast<chrono::seconds>(now - lastTradeTime).count() > cooldownSec;

        //==================== ENTRY ====================//
        if (shares == 0.0 && cooldownPassed && volatility > 0.002) {
            double riskAmount = equity * riskPerTrade;

            // dynamic stop based on volatility
            double stopLossPct = max(0.005, volatility * 0.5);
            double stopDistance = price * stopLossPct;

            shares = riskAmount / stopDistance;

            // cap by available cash
            if (shares * price > cash)
                shares = cash / price;

            cash -= shares * price;
            entry = price;
            lastTradeTime = now;

            cout << "BUY @ " << price
                 << " | Shares: " << shares
                 << " | SL%: " << stopLossPct << "\n";
        }

        //==================== EXIT ====================//
        else if (shares > 0.0) {
            double stopLossPct = max(0.005, volatility * 0.5);

            double takeProfit = entry * (1.0 + stopLossPct * 2.0); // RR 1:2
            double stopLoss = entry * (1.0 - stopLossPct);

            if (price >= takeProfit) {
                cash += shares * price;

                cout << "TAKE PROFIT @ " << price << "\n";

                shares = 0.0;
                lastTradeTime = now;
            }
            else if (price <= stopLoss) {
                cash += shares * price;

                cout << "STOP LOSS @ " << price << "\n";

                shares = 0.0;
                lastTradeTime = now;
            }
        }

        equity = cash + shares * price;

        cout << "Cash: " << cash
             << " | Equity: " << equity << "\n\n";

        this_thread::sleep_for(chrono::seconds(2));
    }

    return 0;
}