#include <iostream>
#include <string>
#include <cstdio>
#include <memory>
#include <thread>
#include <chrono>

using namespace std;

// safer exec with RAII
string exec(const string& cmd) {
    array<char, 256> buffer;
    string result;

    unique_ptr<FILE, decltype(&pclose)> pipe(popen(cmd.c_str(), "r"), pclose);
    if (!pipe) return "";

    while (fgets(buffer.data(), buffer.size(), pipe.get()) != nullptr) {
        result += buffer.data();
    }

    return result;
}

// faster + safer price extraction
double extractPrice(const string& response) {
    const string key = "\"regularMarketPrice\":";
    size_t pos = response.find(key);

    if (pos == string::npos) return -1;

    pos += key.length();

    char* endPtr;
    double price = strtod(response.c_str() + pos, &endPtr);

    return (endPtr == response.c_str() + pos) ? -1 : price;
}

double getPrice(const string& symbol) {
    static const string base =
        "curl -s --connect-timeout 2 \"https://query1.finance.yahoo.com/v7/finance/quote?symbols=";

    string response = exec(base + symbol + "\"");
    if (response.empty()) return -1;

    return extractPrice(response);
}

int main() {
    const string symbol = "AMZN";

    double cash = 10000.0;
    double shares = 0.0;
    double entry = 0.0;

    cout << "=== LIVE TRADING SIM ===\n";

    while (true) {
        double price = getPrice(symbol);

        if (price <= 0) {
            cout << "DATA ERROR\n";
            this_thread::sleep_for(chrono::seconds(2));
            continue;
        }

        cout << "Price: " << price << "\n";

        // BUY (10% allocation)
        if (shares == 0.0) {
            shares = (cash * 0.1) / price;
            cash -= shares * price;
            entry = price;

            cout << "BUY @ " << price << "\n";
        }

        // SELL (take profit)
        else if (price >= entry * 1.01) {
            cash += shares * price;
            shares = 0.0;

            cout << "SELL @ " << price << "\n";
        }

        // STOP LOSS
        else if (price <= entry * 0.99) {
            cash += shares * price;
            shares = 0.0;

            cout << "STOP LOSS @ " << price << "\n";
        }

        double equity = cash + shares * price;
        cout << "Equity: " << equity << "\n\n";

        this_thread::sleep_for(chrono::seconds(2));
    }

    return 0;
}