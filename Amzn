#include <iostream>
#include <string>
#include <cstdio>
#include <cstdlib>
#include <vector>
#include <thread>
#include <chrono>

using namespace std;

// run system curl
string exec(const char* cmd) {
    char buffer[128];
    string result = "";

    FILE* pipe = popen(cmd, "r");
    if (!pipe) return "";

    while (fgets(buffer, sizeof(buffer), pipe) != NULL) {
        result += buffer;
    }

    pclose(pipe);
    return result;
}

// get live price
double getPrice(string symbol) {

    string cmd = "curl -s \"https://query1.finance.yahoo.com/v7/finance/quote?symbols=" + symbol + "\"";
    string response = exec(cmd.c_str());

    if (response.empty()) return -1;

    size_t pos = response.find("\"regularMarketPrice\":");
    if (pos == string::npos) return -1;

    pos += 22;
    size_t end = response.find(",", pos);

    return atof(response.substr(pos, end - pos).c_str());
}

int main() {

    string symbol = "AMZN";

    double cash = 10000;
    double shares = 0;
    double entry = 0;

    cout << "=== ONLINEGDB LIVE AMZN SIM ===\n";

    while (true) {

        double price = getPrice(symbol);

        if (price <= 0) {
            cout << "DATA ERROR (API blocked or market closed)\n";
            this_thread::sleep_for(chrono::seconds(2));
            continue;
        }

        cout << "Price: " << price << endl;

        // BUY
        if (shares == 0) {
            shares = (cash * 0.1) / price;
            cash -= shares * price;
            entry = price;

            cout << "BUY @ " << price << endl;
        }

        // SELL
        if (shares > 0 && price > entry * 1.01) {
            cash += shares * price;
            shares = 0;

            cout << "SELL @ " << price << endl;
        }

        // STOP LOSS
        if (shares > 0 && price < entry * 0.99) {
            cash += shares * price;
            shares = 0;

            cout << "STOP LOSS @ " << price << endl;
        }

        double equity = cash + shares * price;

        cout << "Equity: " << equity << "\n\n";

        this_thread::sleep_for(chrono::seconds(2));
    }

    return 0;
}
