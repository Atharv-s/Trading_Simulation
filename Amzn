using namespace std;

//==================== UTIL ====================//

string exec(const string& cmd) {
    array<char, 256> buffer;
    string result;

    unique_ptr<FILE, decltype(&pclose)> pipe(popen(cmd.c_str(), "r"), pclose);
    if (!pipe) return "";

    while (fgets(buffer.data(), buffer.size(), pipe.get()) != nullptr) {
        result += buffer.data();
    }

    return result;
}

double extractPrice(const string& response) {
    const string key = "\"regularMarketPrice\":";
    size_t pos = response.find(key);

    if (pos == string::npos) return -1;

    pos += key.length();

    char* endPtr;
    double price = strtod(response.c_str() + pos, &endPtr);

    return (endPtr == response.c_str() + pos) ? -1 : price;
}

double getPrice(const string& symbol) {
    static const string base =
        "curl -s --connect-timeout 2 \"https://query1.finance.yahoo.com/v7/finance/quote?symbols=";

    string response = exec(base + symbol + "\"");
    if (response.empty()) return -1;

    return extractPrice(response);
}

//==================== INDICATORS ====================//

double sma(const vector<double>& data, int period) {
    if (data.size() < period) return 0.0;

    return accumulate(data.end() - period, data.end(), 0.0) / period;
}

double momentum(const vector<double>& data, int lookback) {
    if (data.size() < lookback + 1) return 0.0;
    return (data.back() - data[data.size() - 1 - lookback]) / data[data.size() - 1 - lookback];
}

// simple volatility (returns avg absolute return)
double volatility(const vector<double>& data) {
    if (data.size() < 2) return 0.0;

    double sum = 0.0;
    for (size_t i = 1; i < data.size(); ++i) {
        sum += abs((data[i] - data[i - 1]) / data[i - 1]);
    }
    return sum / (data.size() - 1);
}

//==================== MAIN ====================//

int main() {
    const string symbol = "AMZN";

    double cash = 10000.0;
    double shares = 0.0;
    double entry = 0.0;

    double maxEquity = cash;

    const double riskPerTrade = 0.01;
    const double maxDrawdown = 0.10;
    const int cooldownSec = 10;

    vector<double> prices;
    const size_t maxHistory = 50;

    auto lastTradeTime = chrono::steady_clock::now();

    cout << "=== LIVE TRADING SIM (SMART STRATEGY) ===\n";

    while (true) {
        double price = getPrice(symbol);

        if (price <= 0) {
            cout << "DATA ERROR\n";
            this_thread::sleep_for(chrono::seconds(2));
            continue;
        }

        // store history
        prices.push_back(price);
        if (prices.size() > maxHistory)
            prices.erase(prices.begin());

        double fastMA = sma(prices, 5);
        double slowMA = sma(prices, 20);
        double mom = momentum(prices, 5);
        double vol = volatility(prices);

        double equity = cash + shares * price;
        maxEquity = max(maxEquity, equity);

        // 🔴 Drawdown protection
        if ((maxEquity - equity) / maxEquity > maxDrawdown) {
            cout << "MAX DRAWDOWN HIT. STOPPING.\n";
            break;
        }

        cout << "Price: " << price
             << " | FastMA: " << fastMA
             << " | SlowMA: " << slowMA
             << " | Mom: " << mom
             << " | Vol: " << vol << "\n";

        auto now = chrono::steady_clock::now();
        bool cooldownPassed =
            chrono::duration_cast<chrono::seconds>(now - lastTradeTime).count() > cooldownSec;

        //==================== ENTRY ====================//
        bool trendUp = fastMA > slowMA;
        bool momentumUp = mom > 0.001;

        if (shares == 0.0 && cooldownPassed && trendUp && momentumUp) {
            double riskAmount = equity * riskPerTrade;

            double stopLossPct = max(0.005, vol * 2.0);
            double stopDistance = price * stopLossPct;

            shares = riskAmount / stopDistance;

            if (shares * price > cash)
                shares = cash / price;

            cash -= shares * price;
            entry = price;
            lastTradeTime = now;

            cout << "BUY @ " << price
                 << " | Shares: " << shares
                 << " | SL%: " << stopLossPct << "\n";
        }

        //==================== EXIT ====================//
        else if (shares > 0.0) {
            double stopLossPct = max(0.005, vol * 2.0);

            double takeProfit = entry * (1.0 + stopLossPct * 2.0);
            double stopLoss = entry * (1.0 - stopLossPct);

            bool trendDown = fastMA < slowMA;

            if (price >= takeProfit) {
                cash += shares * price;
                shares = 0.0;
                lastTradeTime = now;

                cout << "TAKE PROFIT @ " << price << "\n";
            }
            else if (price <= stopLoss || trendDown) {
                cash += shares * price;
                shares = 0.0;
                lastTradeTime = now;

                cout << "EXIT (SL/Trend) @ " << price << "\n";
            }
        }

        equity = cash + shares * price;

        cout << "Cash: " << cash
             << " | Equity: " << equity << "\n\n";

        this_thread::sleep_for(chrono::seconds(2));
    }

    return 0;
}