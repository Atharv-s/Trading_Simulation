#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

// ================= RISK =================
struct Risk {
    double peakEquity = 10000;
    bool halted = false;

    double maxDrawdown = 0.10;

    void check(double equity) {
        if (equity > peakEquity)
            peakEquity = equity;

        double dd = (peakEquity - equity) / peakEquity;

        if (dd > maxDrawdown) {
            halted = true;
            cout << "\n*** RISK HALT: DRAWDOWN LIMIT ***\n";
        }
    }
};

// ================= MAIN =================
int main() {
    srand(time(0));

    double price = 100;
    double cash = 10000;
    int shares = 0;

    double entry = 0;
    double realizedPnL = 0;

    double ema = 100;          // trend filter
    double volatility = 1;

    int cooldown = 0;

    Risk risk;

    bool running = false;
    char cmd;
    int tick = 0;

    cout << "=== HIGH PnL EFFICIENCY SIM ===\n";
    cout << "s=start | x=stop | q=quit\n";

    while (true) {
        cout << "\ncmd: ";
        cin >> cmd;

        if (cmd == 'q') break;
        if (cmd == 's') {
            running = true;
            cout << "RUNNING HIGH QUALITY MODE\n";
        }
        if (cmd == 'x') {
            running = false;
            cout << "STOPPED\n";
        }

        while (running && !risk.halted) {

            // ================= MARKET =================
            double change = (rand() % 100 - 50) * 0.1;
            price += change;

            // EMA trend (fast)
            ema = 0.9 * ema + 0.1 * price;

            // volatility estimate
            volatility = 0.9 * volatility + 0.1 * abs(change);

            double equity = cash + shares * price;
            risk.check(equity);

            if (risk.halted) break;

            // ================= COOLDOWN =================
            if (cooldown > 0) {
                cooldown--;
            }

            // ================= SIGNAL LOGIC =================

            bool upTrend = price > ema;
            bool strongMove = abs(price - ema) > 1.0;
            bool lowVol = volatility < 2.0;

            // BUY only in strong trend + low noise
            if (cooldown == 0 &&
                upTrend &&
                strongMove &&
                lowVol &&
                cash > price) {

                int qty = (int)(cash * 0.02 / price); // 2% exposure
                if (qty < 1) qty = 1;

                cash -= qty * price;
                shares += qty;
                entry = price;

                cooldown = 5; // prevent overtrading

                cout << "BUY " << qty << " @ " << price << endl;
            }

            // SELL condition (trend reversal or profit)
            if (shares > 0 &&
               (!upTrend || price > entry * 1.02)) {

                realizedPnL += shares * (price - entry);
                cash += shares * price;
                shares = 0;

                cooldown = 5;

                cout << "SELL EXIT @ " << price << endl;
            }

            // ================= OUTPUT =================
            if (tick % 5 == 0) {
                cout << "P:" << price
                     << " EMA:" << ema
                     << " V:" << volatility
                     << " PnL:" << (realizedPnL + shares * (price - entry))
                     << endl;
            }

            tick++;

            // fast loop (no sleep for efficiency)
            if (cin.rdbuf()->in_avail()) {
                cin >> cmd;
                if (cmd == 'x') {
                    running = false;
                    break;
                }
            }
        }
    }

    cout << "\nFINAL PnL: " << realizedPnL << endl;
    return 0;
}
